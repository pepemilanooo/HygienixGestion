{
  "$schema": "https://railway.app/railway.schema.json",
  "projects": [
    {
      "name": "hygienix-saas",
      "services": [
        {
          "name": "backend",
          "source": {
            "root": "backend"
          },
          "volumes": [
            {
              "mountPath": "/data"
            }
          ],
          "build": {
            "builder": "NIXPACKS"
          },
          "deploy": {
            "startCommand": "npx prisma migrate resolve --applied 20260316164455_add_sopralluogo_data || true && npx prisma db push --accept-data-loss && npm start",
            "healthcheckPath": "/api/health"
          }
        },
        {
          "name": "frontend",
          "source": {
            "root": "frontend"
          },
          "build": {
            "builder": "NIXPACKS"
          },
          "deploy": {
            "startCommand": "npx serve -s dist -p $PORT",
            "healthcheckPath": "/"
          }
        }
      ]
    }
  ]
}
